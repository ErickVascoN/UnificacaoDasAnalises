# Exemplo de arquivo .env
# Copie este arquivo como '.env' e precha com suas informações

# Google Sheets IDs
SHEET_ID_CORTE=sua_sheet_id_aqui
SHEET_ID_PRODUCAO=sua_sheet_id_aqui

# Credenciais Google (caminho para arquivo JSON)
# Baixe em: https://console.cloud.google.com/
GOOGLE_APPLICATION_CREDENTIALS=./credenciais.json
